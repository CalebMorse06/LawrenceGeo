# Mapbox — https://account.mapbox.com/access-tokens/ (restrict to your domain in production)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps JS API key with Street View enabled
# https://console.cloud.google.com/google/maps-apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Supabase project — Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Used by scripts/seed-locations.ts. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
